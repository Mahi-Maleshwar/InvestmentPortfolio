# Copy to .env in this folder (backend/) and adjust if needed.

# Database
DATABASE_URL=mongodb://localhost:27017/portfolio_db

# Email Configuration (for password reset OTP)
# Leave SMTP_USER empty to print OTP to console (development mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# OpenAI API Key (for AI chatbot) - Optional, not required for rule-based chatbot
# Leave empty to use the built-in portfolio analysis chatbot
OPENAI_API_KEY=
